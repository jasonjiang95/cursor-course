# Optional: comma-separated origins (pydantic-settings 字段 cors_origins)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========== Phase 3：百炼 / DashScope（勿将真实 Key 提交 git）==========
# DASHSCOPE_API_KEY=
# 可选：地域与 API Key 绑定，新加坡国际版示例 dashscope.base_http_api_url
# DASHSCOPE_BASE_HTTP_API_URL=https://dashscope-intl.aliyuncs.com/api/v1
# /chat/stream 二阶段是否用 dashscope.Generation 流式（false 则仅本地切块）
# CHAT_STREAM_DASHSCOPE_GENERATION=true

# SQLite 路径（相对于 backend 当前工作目录，可按部署调整）
# META_DB_PATH=./data/meta.db
# APP_DB_PATH=./data/app.db
